# Cloudflare Pages cache headers

# Hashed build assets never change — cache forever, immutable.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Cover frames + gallery shots are stable — cache a week, revalidate in background.
/covers/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/gallery/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
